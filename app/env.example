# SmartSpace AR Database Configuration
# Copy this file to .env and update with your actual database credentials

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smartspace_ar
DB_USERNAME=root
DB_PASSWORD=your_mysql_password_here

# Backend API (Node.js)
# For laptop/desktop/web: http://localhost:4000/api
# For Android emulator: http://10.0.2.2:4000/api
# For physical device: http://YOUR_COMPUTER_IP:4000/api (e.g., http://192.168.1.100:4000/api)
API_BASE_URL=http://localhost:4000/api
API_TIMEOUT=10

# Database Connection Settings
DB_TIMEOUT=30
DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=2

# Application Settings
APP_ENV=development
APP_DEBUG=true

# Security Keys (generate new ones for production)
JWT_SECRET=your_jwt_secret_key_here
API_KEY=your_api_key_here

# External Services (optional)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Firebase Configuration (for 3D model uploads)
# Get these values from Firebase Console > Project Settings > General > Your apps
# For web app, you'll see these in the Firebase config object
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
# Optional: Custom base path for 3D models in Storage (default: '3d-models')
FIREBASE_STORAGE_BASE_PATH=3d-models

# Google Drive (deprecated - use Firebase Storage instead)
# GOOGLE_DRIVE_FOLDER_ID=your_root_drive_folder_id
# GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENTS\n-----END PRIVATE KEY-----\n"

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM=SmartSpace AR <your_email@gmail.com>













