APP_NAME=SmartSpaceBackend
APP_ENV=development
APP_DEBUG=true
PORT=4000

DB_HOST=localhost
DB_PORT=3306
DB_NAME=smartspace_ar
DB_USERNAME=smartspace_user
DB_PASSWORD=smartspace_password
DB_TIMEOUT=5
DB_CONNECTION_LIMIT=10

# PayMongo (test keys from https://dashboard.paymongo.com — use sk_test_... for sandbox)
PAYMONGO_SECRET_KEY=
# Webhook signing secret from PayMongo dashboard (optional for local dev — verification skipped if empty)
PAYMONGO_WEBHOOK_SECRET=
# Public base URL of this API (no /api suffix). Required in production for correct
# avatar/upload absolute URLs and PayMongo defaults — e.g. https://your-service.up.railway.app
PUBLIC_API_BASE_URL=http://localhost:4000

# Android App Links — same host as PUBLIC_API_BASE_URL must serve /.well-known/assetlinks.json
# (this API does when both vars below are set). Then the signup email HTTPS link can open the APK.
# ANDROID_APP_LINK_PACKAGE_NAME=com.example.smartspace_ar
# ANDROID_APP_LINK_SHA256_CERT_FINGERPRINTS=AA:BB:CC:...

# Resend (simple transactional email on Railway and similar hosts)
# Create a Resend project, then set RESEND_API_KEY from your Resend dashboard.
RESEND_API_KEY=

# Sender used in the `from:` field for all emails.
# Resend requires the sender address to be authorized in your Resend settings.
# (We reuse SMTP_FROM as the single source of truth for the sender string.)
SMTP_FROM=SmartSpace AR <your_email@gmail.com>

# SendGrid (works without a custom domain via "Single Sender Verification")
# 1) Create a SendGrid API key
# 2) Verify a Sender Identity (can be a Gmail address, but must be verified in SendGrid UI)
SENDGRID_API_KEY=
SENDGRID_FROM=Wood Home Furniture Trading <woodhomefurniture.contact@gmail.com>

# Optional: HTTPS URL to your logo for verification / transactional HTML emails (host on CDN, Firebase, or your API).
# EMAIL_LOGO_URL=https://your-cdn.com/logo.png

# Supabase Storage — when SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set, uploads go here (keep MySQL as app DB).
# Dashboard: create a Storage bucket, make it public for reads (or add policy) so model/image URLs work in the browser.
# Use service_role key only on the server (Railway secrets), never in the Flutter app.
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=smartspace-uploads
# SUPABASE_STORAGE_KEY_PREFIX=smartspace

# Cloudinary — used only when Supabase Storage is NOT configured. GLB/GLTF use resource_type raw; images use image.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=smartspace

# Optional: absolute path for uploaded files (models, images). Use a persistent disk path in production.
# UPLOADS_ROOT=/var/data/uploads
# Optional overrides (defaults: {PUBLIC_API_BASE_URL}/api/paymongo-return/success|cancel)
# PAYMONGO_SUCCESS_URL=http://localhost:4000/api/paymongo-return/success
# PAYMONGO_CANCEL_URL=http://localhost:4000/api/paymongo-return/cancel

