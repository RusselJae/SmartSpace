# SmartSpace AR Database Configuration
# Copy this file to .env and update with your actual database credentials

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=smartspace_ar
DB_USERNAME=root
DB_PASSWORD=root

# Database Connection Settings
DB_TIMEOUT=30
DB_MAX_CONNECTIONS=100
DB_MIN_CONNECTIONS=2

# Backend API (Node.js)
API_BASE_URL=http://192.168.254.116/api

#192.168.254.109
#192.168.254.115 - Kapit Lang
#192.168.43.213 - Mobile Data

API_TIMEOUT=10

# Application Settings
APP_ENV=development
APP_DEBUG=true

ADMIN_EMAIL=admin@smartspace.local
ADMIN_PASSWORD=admin123

# Security Keys (generate new ones for production)
JWT_SECRET=your_jwt_secret_key_here
API_KEY=your_api_key_here

# External Services (optional)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Firebase Configuration (optional)
   FIREBASE_API_KEY=your_api_key_here
   FIREBASE_APP_ID=your_app_id_here
   FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
   FIREBASE_PROJECT_ID=your_project_id_here
   FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
   FIREBASE_STORAGE_BASE_PATH=3d-models


