<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      API 31+: System splash screen uses a circular mask on the animated icon.
      Pair white background with [splash_screen_icon] (inset) so the mark is not cropped.
    -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_screen_icon</item>
    </style>
</resources>
