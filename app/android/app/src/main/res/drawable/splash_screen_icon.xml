<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ draws the splash icon inside a circular mask. The generated
  launcher foreground is often edge-to-edge, which reads as "zoomed" or clipped.
  Insetting the drawable gives the artwork breathing room inside that mask.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/ic_launcher_foreground"
    android:insetLeft="26dp"
    android:insetTop="26dp"
    android:insetRight="26dp"
    android:insetBottom="26dp" />
